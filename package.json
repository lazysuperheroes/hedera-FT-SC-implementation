{
  "name": "@lazysuperheroes/hedera-ft-sc",
  "version": "2.0.0",
  "description": "Hedera Fungible Token Smart Contract Treasury - creates and manages immutable fungible tokens via a no-keys smart contract treasury pattern",
  "main": "index.js",
  "scripts": {
    "test": "npx hardhat test",
    "compile": "npx hardhat compile",
    "predeploy": "npx hardhat compile",
    "deploy": "npx hardhat run scripts/deploy.js",
    "premintToken": "npx hardhat compile",
    "mintToken": "npx hardhat run scripts/mintToken.js",
    "interact": "npx hardhat run scripts/interact.js",
    "send": "node scripts/sendFungible.js",
    "setAllowance": "node scripts/setAllowance.js",
    "adjustWL": "node scripts/adjustWL.js",
    "associateToken": "node scripts/associateToken.js",
    "checkAllowance": "node scripts/checkAllowance.js",
    "transferHbar": "node scripts/transferHbar.js",
    "logs": "node scripts/getContractLogs.js",
    "info": "node scripts/getContractInfo.js",
    "decodeError": "node scripts/decodeSmartContractError.js",
    "solhint": "solhint -f table contracts/**/*.sol",
    "lint": "eslint scripts/ utils/ test/"
  },
  "keywords": [
    "hedera",
    "hts",
    "fungible-token",
    "smart-contract",
    "treasury",
    "no-keys",
    "immutable",
    "hbar",
    "web3",
    "blockchain"
  ],
  "author": "Lazy Super Heroes team (https://github.com/lazysuperheroes)",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/lazysuperheroes/hedera-ft-sc"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "index.js",
    "utils/",
    "contracts/",
    "artifacts/contracts/FungibleTokenCreator.sol/FungibleTokenCreator.json"
  ],
  "dependencies": {
    "@hashgraph/sdk": "2.79.0",
    "@lazysuperheroes/hedera-multisig": "^1.2.2",
    "axios": "^1.13.2",
    "dotenv": "^16.0.3",
    "ethers": "6.16.0",
    "readline-sync": "^1.4.10"
  },
  "devDependencies": {
    "@openzeppelin/contracts": "^4.9.6",
    "chai": "^4.3.6",
    "eslint": "^8.21.0",
    "hardhat": "^2.22.7",
    "solhint": "^3.3.7"
  }
}
